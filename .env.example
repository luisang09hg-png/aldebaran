# .env.example
# -------------------
# PostgreSQL connection URL (compatible with Prisma)
# Example: postgres://user:password@localhost:5432/aldebaran
DATABASE_URL="postgresql://postgres:secret@localhost:5432/aldebaran?schema=public"

# JWT secrets (use strong random strings in production)
JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_refresh_jwt_secret"

# Server configuration
PORT=4000
HOST=0.0.0.0
